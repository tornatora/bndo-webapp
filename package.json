{
  "name": "bndo-bandi-assistant",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.17 <22"
  },
  "scripts": {
    "dev": "NEXT_DISABLE_WEBPACK_CACHE=1 next dev",
    "clean": "rm -rf .next",
    "clean:all": "rm -rf .next .turbo node_modules/.cache",
    "dev:clean": "npm run clean:all && NEXT_DISABLE_WEBPACK_CACHE=1 next dev",
    "build": "npm run clean && next build",
    "start": "next start",
    "preview:stable": "npm run build && npm run start -- --port 3300",
    "lint": "next lint",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "smoke:v2": "bash scripts/smoke-v2.sh",
    "scanner:cases": "node scripts/check-scanner-real-cases.mjs",
    "conversation:readiness": "node scripts/check-conversation-readiness.mjs",
    "conversation:quality": "node scripts/check-conversation-quality.mjs",
    "conversation:intent-cases": "node scripts/check-conversation-intent-cases.mjs",
    "test:phase-a": "npx tsx scripts/test-phase-a-unit.ts",
    "test:phase-b": "npx tsx scripts/test-phase-b-unit.ts",
    "test:phase-c": "npx tsx scripts/test-phase-c-unit.ts",
    "stress:safe": "node scripts/stress-safe.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "0.5.2",
    "@supabase/supabase-js": "2.48.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.473.0",
    "next": "^14.2.18",
    "pdf-parse": "^2.4.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "stripe": "^17.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.18",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
