# Optional public override. Leave empty to use same-origin scanner APIs from bndo-final.
NEXT_PUBLIC_API_BASE_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI / chat
OPENAI_API_KEY=
OPENAI_MODEL_SIMPLE=gpt-4.1-mini
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MODEL_COMPLEX=gpt-4o
OPENAI_MODEL_EXTRACTION=gpt-4o-mini
# true = deterministic-only chat (no OpenAI token usage)
CHAT_NO_OPENAI_TOKENS=false
# true = allow OpenAI usage also in local/dev (default false to save credits)
CHAT_ALLOW_OPENAI_IN_DEV=false
# hard-restore chat backend (69ce95 baseline)
CHAT_BACKEND_PROXY_MODE=on
CHAT_PROXY_BASE_URL=https://69ce95a19126a43a447cb472--cheerful-cobbler-f23efc.netlify.app
CHAT_PROXY_TIMEOUT_MS=30000
SERPER_API_KEY=
WEBSEARCH_PROVIDER=free
WEBSEARCH_CACHE_TTL_SEC=21600
WEBSEARCH_ALLOW_PAID_FALLBACK=0
AI_CHAT_V2=true
CHAT_DETERMINISTIC_V3=true
MATCHING_ENGINE_V3=true
MATCHING_DIAGNOSTICS=false
AI_MAX_BUDGET_EUR=10
AI_USAGE_TRACK_PATH=/tmp/bndo-ai-usage.json
USD_TO_EUR=0.92

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Email
RESEND_API_KEY=
RESEND_FROM_EMAIL="BNDO <noreply@bndo.it>"

# Scanner bandi server-side
SCANNER_API_ENABLED=false
SCANNER_API_BASE_URL=
SCANNER_API_EMAIL=
SCANNER_API_PASSWORD=
SCANNER_API_TIMEOUT_MS=20000
BANDI_CACHE_PATH=/tmp/bndo-bandi-cache.json

# Browser automation (Step9 Compila Bando)
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
BROWSERBASE_EXTENSION_ID=
